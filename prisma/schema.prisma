generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  HOLIDAY
}

enum FeeStatus {
  PENDING
  PAID
  PARTIAL
  WAIVED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CalendarEventType {
  HOLIDAY
  EXAM
  SPORTS
  MEETING
  OTHER
}

model School {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(200)
  slug           String   @unique @db.VarChar(60)
  address        String?  @db.Text
  phone          String?  @db.VarChar(20)
  email          String?  @db.VarChar(100)
  logoUrl        String?  @db.VarChar(500)
  primaryColor   String?  @db.VarChar(10)
  currentSession String   @default("2025-26") @db.VarChar(20)
  isActive       Boolean  @default(true)
  plan           String   @default("basic") @db.VarChar(30)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users                User[]
  students             Student[]
  classes              ClassSection[]
  subjects             Subject[]
  feeTypes             FeeType[]
  feeStructures        FeeStructure[]
  feeRecords           FeeRecord[]
  examTypes            ExamType[]
  exams                Exam[]
  markEntries          MarkEntry[]
  attendanceRecords    Attendance[]
  transferCertificates TransferCertificate[]
  calendarEvents       CalendarEvent[]
  notifications        Notification[]
  leaveRequests        LeaveRequest[]
  teacherAssignments   TeacherAssignment[]
}

model User {
  id               Int      @id @default(autoincrement())
  schoolId         Int
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  username         String   @unique @db.VarChar(100)
  email            String?  @db.VarChar(200)
  phone            String?  @db.VarChar(20)
  fullName         String   @db.VarChar(200)
  hashedPassword   String   @db.VarChar(200)
  role             Role     @default(TEACHER)
  isActive         Boolean  @default(true)
  avatarUrl        String?  @db.VarChar(500)
  employeeId       String?  @db.VarChar(50)
  subjectSpecialty String?  @db.VarChar(100)
  classTeacherOf   String?  @db.VarChar(30)
  fcmToken         String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  markedAttendances  Attendance[]          @relation("MarkedBy")
  enteredMarks       MarkEntry[]           @relation("EnteredBy")
  collectedFees      FeeRecord[]           @relation("CollectedBy")
  paymentTransactions PaymentTransaction[]  @relation("TransactionCollectedBy")
  issuedTCs          TransferCertificate[] @relation("IssuedBy")
  leaveRequests      LeaveRequest[]        @relation("LeaveUser")
  approvedLeaves     LeaveRequest[]        @relation("LeaveApprover")
  notifications      Notification[]
  concessions        Concession[]          @relation("ApprovedBy")
  teacherAssignments TeacherAssignment[]   @relation("TeacherAssignments")
  createdExams       Exam[]                @relation("ExamCreatedBy")
  studentProfile     Student?

  @@index([schoolId])
  @@index([schoolId, role])
}

model ClassSection {
  id        Int     @id @default(autoincrement())
  schoolId  Int
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  className String  @db.VarChar(20)
  section   String  @default("A") @db.VarChar(5)
  isActive  Boolean @default(true)

  students           Student[]
  exams              Exam[]
  teacherAssignments TeacherAssignment[]
  feeStructures      FeeStructure[]

  @@unique([schoolId, className, section])
  @@index([schoolId])
}

model Subject {
  id       Int     @id @default(autoincrement())
  schoolId Int
  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name     String  @db.VarChar(100)
  code     String? @db.VarChar(20)
  isActive Boolean @default(true)

  exams              Exam[]
  teacherAssignments TeacherAssignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model TeacherAssignment {
  id             Int          @id @default(autoincrement())
  schoolId       Int
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId      Int
  teacher        User         @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  classSectionId Int
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  subjectId      Int?
  subject        Subject?     @relation(fields: [subjectId], references: [id])
  isClassTeacher Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([teacherId, classSectionId, subjectId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([classSectionId])
}

model Student {
  id             Int       @id @default(autoincrement())
  schoolId       Int
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentUid     String    @unique @db.VarChar(30)
  fullName       String    @db.VarChar(200)
  fatherName     String    @db.VarChar(200)
  motherName     String?   @db.VarChar(200)
  dob            DateTime? @db.Date
  gender         Gender    @default(MALE)
  classSectionId Int?
  classSection   ClassSection? @relation(fields: [classSectionId], references: [id])
  rollNumber     Int?
  phone          String    @db.VarChar(20)
  parentPhone    String?   @db.VarChar(20)
  email          String?   @db.VarChar(200)
  address        String?   @db.Text
  admissionDate  DateTime? @db.Date
  bloodGroup     String?   @db.VarChar(10)
  prevSchool     String?   @db.VarChar(200)
  photoUrl       String?   @db.VarChar(500)
  isActive       Boolean   @default(true)
  userId         Int?      @unique
  user           User?     @relation(fields: [userId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  feeRecords           FeeRecord[]
  concession           Concession?
  attendanceRecords    Attendance[]
  markEntries          MarkEntry[]
  transferCertificates TransferCertificate[]

  @@index([schoolId])
  @@index([schoolId, isActive])
  @@index([classSectionId])
}

model Attendance {
  id         Int              @id @default(autoincrement())
  schoolId   Int
  school     School           @relation(fields: [schoolId], references: [id])
  studentId  Int
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date       DateTime         @db.Date
  status     AttendanceStatus @default(PRESENT)
  markedById Int?
  markedBy   User?            @relation("MarkedBy", fields: [markedById], references: [id])
  remarks    String?          @db.Text
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@index([studentId])
}

model ExamType {
  id        Int     @id @default(autoincrement())
  schoolId  Int
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String  @db.VarChar(100)
  maxMarks  Int     @default(100)
  passMarks Int     @default(33)
  weightPct Int     @default(100)
  isActive  Boolean @default(true)

  exams Exam[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Exam {
  id             Int           @id @default(autoincrement())
  schoolId       Int
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  examTypeId     Int
  examType       ExamType      @relation(fields: [examTypeId], references: [id])
  classSectionId Int?
  classSection   ClassSection? @relation(fields: [classSectionId], references: [id])
  subjectId      Int?
  subject        Subject?      @relation(fields: [subjectId], references: [id])
  examDate       DateTime?     @db.Date
  session        String        @default("2025-26") @db.VarChar(20)
  isPublished    Boolean       @default(false)
  isQuiz         Boolean       @default(false)   // private quiz, visible only to creator
  createdById    Int?
  createdBy      User?         @relation("ExamCreatedBy", fields: [createdById], references: [id])

  entries MarkEntry[]

  @@index([schoolId, session])
  @@index([classSectionId])
}

model MarkEntry {
  id            Int      @id @default(autoincrement())
  schoolId      Int
  school        School   @relation(fields: [schoolId], references: [id])
  studentId     Int
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId        Int
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  marksObtained Decimal  @db.Decimal(6, 2)
  grade         String?  @db.VarChar(5)
  remarks       String?  @db.Text
  enteredById   Int?
  enteredBy     User?    @relation("EnteredBy", fields: [enteredById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, examId])
  @@index([schoolId])
  @@index([studentId])
}

model FeeType {
  id                Int     @id @default(autoincrement())
  schoolId          Int
  school            School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name              String  @db.VarChar(100)
  description       String? @db.Text
  amount            Decimal @default(0) @db.Decimal(12, 2)
  isMonthly         Boolean @default(false)
  isActive          Boolean @default(true)
  applicableClasses Json?

  records    FeeRecord[]
  structures FeeStructure[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model FeeStructure {
  id             Int          @id @default(autoincrement())
  schoolId       Int
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeTypeId      Int
  feeType        FeeType      @relation(fields: [feeTypeId], references: [id], onDelete: Cascade)
  classSectionId Int
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  amount         Decimal      @db.Decimal(12, 2)
  dueDate        DateTime?    @db.Date
  session        String       @db.VarChar(20)
  isActive       Boolean      @default(true)

  @@unique([schoolId, feeTypeId, classSectionId, session])
  @@index([schoolId])
  @@index([classSectionId])
}

model FeeRecord {
  id            Int       @id @default(autoincrement())
  schoolId      Int
  school        School    @relation(fields: [schoolId], references: [id])
  studentId     Int
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeTypeId     Int
  feeType       FeeType   @relation(fields: [feeTypeId], references: [id])
  amountDue     Decimal   @db.Decimal(12, 2)
  amountPaid    Decimal   @default(0) @db.Decimal(12, 2)
  concessionAmt Decimal   @default(0) @db.Decimal(12, 2)
  dueDate       DateTime? @db.Date
  paidDate      DateTime? @db.Date
  status        FeeStatus @default(PENDING)
  receiptNumber String?   @unique @db.VarChar(50)
  paymentMode   String?   @db.VarChar(30)
  remarks       String?   @db.Text
  collectedById Int?
  collectedBy   User?     @relation("CollectedBy", fields: [collectedById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions  PaymentTransaction[]

  @@index([schoolId, status])
  @@index([studentId])
  @@index([schoolId, dueDate])
}

model PaymentTransaction {
  id            Int       @id @default(autoincrement())
  schoolId      Int
  feeRecordId   Int
  feeRecord     FeeRecord @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)
  amount        Decimal   @db.Decimal(12, 2)
  paymentMode   String    @db.VarChar(30)
  paidDate      DateTime  @db.Date
  receiptNumber String?   @db.VarChar(50)
  collectedById Int?
  collectedBy   User?     @relation("TransactionCollectedBy", fields: [collectedById], references: [id])
  remarks       String?   @db.Text
  createdAt     DateTime  @default(now())

  @@index([feeRecordId])
  @@index([schoolId])
}

model Concession {
  id           Int      @id @default(autoincrement())
  schoolId     Int
  studentId    Int      @unique
  student      Student  @relation(fields: [studentId], references: [id])
  percentage   Int      @default(0)
  reason       String?  @db.Text
  approvedById Int?
  approvedBy   User?    @relation("ApprovedBy", fields: [approvedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TransferCertificate {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  tcNumber    String   @unique @db.VarChar(30)
  leavingDate DateTime @db.Date
  issueDate   DateTime @db.Date
  reason      String?  @db.Text
  conduct     String   @default("Good") @db.VarChar(30)
  remarks     String?  @db.Text
  pdfUrl      String?  @db.VarChar(500)
  issuedById  Int?
  issuedBy    User?    @relation("IssuedBy", fields: [issuedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([schoolId])
  @@index([studentId])
}

model CalendarEvent {
  id          Int               @id @default(autoincrement())
  schoolId    Int
  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String            @db.VarChar(200)
  description String?           @db.Text
  startDate   DateTime          @db.Date
  endDate     DateTime          @db.Date
  eventType   CalendarEventType @default(OTHER)
  isPublic    Boolean           @default(true)
  color       String?           @db.VarChar(10)
  createdById Int?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([schoolId, startDate])
}

model LeaveRequest {
  id           Int         @id @default(autoincrement())
  schoolId     Int
  school       School      @relation(fields: [schoolId], references: [id])
  userId       Int
  user         User        @relation("LeaveUser", fields: [userId], references: [id], onDelete: Cascade)
  fromDate     DateTime    @db.Date
  toDate       DateTime    @db.Date
  reason       String      @db.Text
  leaveType    String      @default("casual") @db.VarChar(50)
  status       LeaveStatus @default(PENDING)
  approvedById Int?
  approvedBy   User?       @relation("LeaveApprover", fields: [approvedById], references: [id])
  adminRemark  String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([schoolId, status])
  @@index([userId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  recipientId Int?
  recipient   User?    @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  title       String   @db.VarChar(200)
  body        String   @db.Text
  notifType   String   @default("general") @db.VarChar(50)
  isRead      Boolean  @default(false)
  linkType    String?  @db.VarChar(50)
  linkId      Int?
  sentViaPush Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([schoolId, recipientId])
  @@index([recipientId, isRead])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  schoolId   Int
  userId     Int?
  action     String   @db.VarChar(100)
  entityType String?  @db.VarChar(50)
  entityId   Int?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([schoolId, entityType, entityId])
}
